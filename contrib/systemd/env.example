# op-sign-proxy configuration.
#
# Install this file at ~/.config/op-sign-proxy/env with mode 0600:
#
#     install -d -m 0700 ~/.config/op-sign-proxy
#     install -m 0600 contrib/systemd/env.example ~/.config/op-sign-proxy/env
#     $EDITOR ~/.config/op-sign-proxy/env
#
# systemd loads this file via EnvironmentFile= before starting the service.

# REQUIRED. 1Password service-account token.
# Create one at https://developer.1password.com/docs/service-accounts/
OP_SERVICE_ACCOUNT_TOKEN=ops_REPLACE_ME

# REQUIRED. Secret reference to the SSH private key field of a 1Password
# item. Format: op://<vault>/<item>/<field>. For a standard "SSH Key" item
# the field is typically "private key".
OP_SSH_KEY_REF=op://Personal/Git Signing/private key

# Optional. Listen address for the HTTP server. Loopback-only by default.
# Change to 0.0.0.0:7221 if you need containers on a bridge network to
# reach the proxy via --add-host=host.docker.internal:host-gateway (this
# exposes the proxy to any process on the host — prefer --network host
# when possible).
#OP_SIGN_PROXY_ADDR=127.0.0.1:7221

# Optional. SSHSIG namespace. Git expects "git" and there is no reason to
# change this unless you are using the proxy for something other than git.
#OP_SIGN_PROXY_NAMESPACE=git
